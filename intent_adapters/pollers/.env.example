# Personal Intelligence OS adapter config
PIOS_SERVER_URL=http://127.0.0.1:5180

# Gmail adapter
PIOS_GMAIL_ACCESS_TOKEN=
PIOS_GMAIL_USER=me
PIOS_GMAIL_QUERY=newer_than:2d
PIOS_GMAIL_MAX_RESULTS=12

# Slack adapter
PIOS_SLACK_BOT_TOKEN=
PIOS_SLACK_CHANNELS=C01234567,C08987654
PIOS_SLACK_MAX_RESULTS=20

# Google Workspace (Drive Activity API)
PIOS_GOOGLE_ACCESS_TOKEN=
PIOS_WORKSPACE_MAX_RESULTS=20

# Granola adapter (directory of exported notes)
PIOS_GRANOLA_EXPORT_DIR=~/Documents/Granola Exports
